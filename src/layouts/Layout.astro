---
import '../styles/global.css';
import Preloader from '../components/Preloader.astro';
import type { Lang } from '../i18n/index.ts';

interface Props {
  title:       string;
  description: string;
  lang:        Lang;
  locale:      string;
}
const { title, description, lang, locale } = Astro.props;

const site = Astro.site ?? new URL('https://diegohernandez.dev');
const canonicalURL = new URL(Astro.url.pathname, site).href;
const hrefEs  = new URL('/',    site).href;
const hrefEn  = new URL('/en/', site).href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#060B14" />
    <meta name="robots" content="index, follow" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalURL} />

    <!-- hreflang — URLs absolutas para SEO multiidioma -->
    <link rel="alternate" hreflang="es"        href={hrefEs} />
    <link rel="alternate" hreflang="en"        href={hrefEn} />
    <link rel="alternate" hreflang="x-default" href={hrefEs} />

    <!-- Prefetch para imágenes de proyectos (Unsplash, lazy-loaded) -->
    <link rel="dns-prefetch" href="https://images.unsplash.com" />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale"      content={locale} />
    <meta name="twitter:card"       content="summary_large_image" />
    <meta name="twitter:title"      content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body>
    <Preloader />
    <slot />

    <script>
      function initChrome(): void {
        const nav = document.getElementById('nav');
        if (nav) {
          const onScroll = (): void => { nav.classList.toggle('scrolled', window.scrollY > 24); };
          onScroll();
          window.addEventListener('scroll', onScroll, { passive: true });

          const burger = nav.querySelector('.nav__burger');
          burger?.addEventListener('click', () => {
            const open = nav.classList.toggle('menu-open');
            burger.setAttribute('aria-expanded', String(open));
          });
          nav.querySelectorAll('.nav__mobile a').forEach((a) =>
            a.addEventListener('click', () => {
              nav.classList.remove('menu-open');
              burger?.setAttribute('aria-expanded', 'false');
            })
          );
        }

        const items = document.querySelectorAll('[data-reveal]');
        if ('IntersectionObserver' in window && items.length) {
          const io = new IntersectionObserver(
            (entries) => { entries.forEach((e) => e.target.classList.toggle('is-in', e.isIntersecting)); },
            { threshold: 0.18, rootMargin: '0px 0px -6% 0px' }
          );
          items.forEach((el) => io.observe(el));
        } else {
          items.forEach((el) => el.classList.add('is-in'));
        }
      }

      if (document.readyState !== 'loading') initChrome();
      else document.addEventListener('DOMContentLoaded', initChrome);
      document.addEventListener('astro:page-load', initChrome);
    </script>
  </body>
</html>
