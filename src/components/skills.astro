<style>
  #habilidades {
    padding: 8rem 6rem;
    background: rgba(255,255,255,0.01);
    border-top: 1px solid rgba(255,255,255,0.04);
  }

  .skills-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .label-line {
    width: 40px;
    height: 1px;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  .label-text {
    font-size: 0.75rem;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .skills-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3.5rem, 8vw, 8rem);
    line-height: 0.9;
    letter-spacing: 2px;
    margin-bottom: 5rem;
  }

  .reveal-text {
    display: block;
    opacity: 0;
    transform: translateY(60px);
  }

  .accent-stroke {
    color: transparent;
    -webkit-text-stroke: 2px var(--color-accent);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem 6rem;
  }

  .skill-category {
    opacity: 0;
    transform: translateY(40px);
  }

  .category-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .category-icon {
    color: var(--color-accent);
    font-size: 0.9rem;
  }

  .category-header h3 {
    font-size: 0.8rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-text);
    font-weight: 500;
  }

  .skill-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .skill-list li {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .skill-list li span:last-child {
    font-size: 0.8rem;
    color: var(--color-muted);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .skill-bar {
    display: block;
    height: 2px;
    background: rgba(255,255,255,0.06);
    border-radius: 2px;
    position: relative;
    overflow: hidden;
  }

  .skill-bar::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 0%;
    background: linear-gradient(to right, var(--color-accent), var(--color-accent-2));
    border-radius: 2px;
    transition: width 1.2s ease;
  }

  .skill-bar.animated::after {
    width: var(--bar-width);
  }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    #habilidades {
      padding: 6rem 3rem;
    }

    .skills-grid {
      gap: 3rem 4rem;
    }
  }

  @media (max-width: 768px) {
    #habilidades {
      padding: 5rem 1.5rem;
