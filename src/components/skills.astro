    .accent-stroke {
      -webkit-text-stroke: 1px var(--color-accent);
    }

    .skills-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .category-header {
      margin-bottom: 1.25rem;
    }

    .skill-list {
      gap: 1rem;
    }
  }

  @media (max-width: 480px) {
    #habilidades {
      padding: 4rem 1.25rem;
    }

    .skills-title {
      font-size: clamp(2.5rem, 12vw, 4rem);
      margin-bottom: 2.5rem;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.to('.skills-title .reveal-text', {
    opacity: 1,
    y: 0,
    duration: 1,
    stagger: 0.2,
    ease: 'power4.out',
    scrollTrigger: {
      trigger: '#habilidades',
      start: 'top 75%',
    }
  });

  document.querySelectorAll('.skill-category').forEach((cat: any) => {
    const delay = parseFloat(cat.getAttribute('data-delay') || '0');
    gsap.to(cat, {
      opacity: 1,
      y: 0,
      duration: 0.8,
      delay,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: '#habilidades',
        start: 'top 70%',
      }
    });
  });

  document.querySelectorAll('.skill-bar').forEach((bar: any) => {
    const width = bar.getAttribute('data-width');
    bar.style.setProperty('--bar-width', width + '%');
    ScrollTrigger.create({
      trigger: bar,
      start: 'top 90%',
      onEnter: () => bar.classList.add('animated'),
      once: true
    });
  });
</script>