---
// Pantalla de carga: cubre el sitio hasta que las imágenes terminan de cargar.
// Barra de progreso real + monograma DH.
---

<div class="preloader" id="preloader" role="status" aria-live="polite" aria-label="Cargando">
  <div class="preloader__inner">
    <!-- Monograma DH en hexágono -->
    <svg class="preloader__logo" width="78" height="78" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M30 4 L52 17 L52 43 L30 56 L8 43 L8 17 Z" fill="rgba(56,189,248,0.07)" />
      <path d="M30 11 L46 20 L46 40 L30 49 L14 40 L14 20 Z" stroke="rgba(56,189,248,0.14)" stroke-width="0.6" fill="none" />
      <text x="30" y="32" text-anchor="middle" dominant-baseline="middle"
        font-family="Helvetica Neue, Arial, sans-serif" font-weight="800" font-size="15"
        fill="#38BDF8" letter-spacing="-0.5">DH</text>
      <path class="preloader__ring" d="M30 4 L52 17 L52 43 L30 56 L8 43 L8 17 Z"
        stroke="#0EA5E9" stroke-width="1.3" fill="none" />
    </svg>

    <div class="preloader__word">DIEGO H.</div>

    <!-- Barra de progreso real -->
    <div class="preloader__track">
      <div class="preloader__fillbar" data-pl-bar></div>
    </div>
    <div class="preloader__pct" data-pl-pct>0%</div>
  </div>
</div>

<style is:global>
  html.is-loading, html.is-loading body { overflow: hidden; }
</style>

<style>
  .preloader {
    position: fixed; inset: 0; z-index: 99999;
    display: grid; place-items: center;
    background: var(--cosmos);
    transition: opacity 0.6s var(--ease);
  }
  .preloader.is-done { opacity: 0; pointer-events: none; }

  .preloader::after {
    content: ""; position: absolute; inset: 0; opacity: 0.03; pointer-events: none;
    background-image: radial-gradient(circle, rgba(255,255,255,0.4) 1px, transparent 1px);
    background-size: 4px 4px;
  }
  .preloader::before {
    content: ""; position: absolute; width: min(520px, 90vw); height: min(520px, 90vw); border-radius: 50%;
    background: radial-gradient(circle, rgba(56,189,248,0.10), transparent 65%);
    filter: blur(20px); animation: plHalo 3.5s var(--ease) infinite;
  }
  @keyframes plHalo { 0%,100% { transform: scale(0.9); opacity: 0.6; } 50% { transform: scale(1.1); opacity: 1; } }

  .preloader__inner { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; }

  .preloader__logo {
    margin-bottom: 22px; overflow: visible;
    opacity: 0; transform: scale(0.7);
    animation: plLogoIn 0.7s var(--ease) 0.15s forwards, plLogoPulse 2.6s var(--ease) 0.9s infinite;
  }
  @keyframes plLogoIn { to { opacity: 1; transform: scale(1); } }
  @keyframes plLogoPulse {
    0%,100% { transform: scale(1);    opacity: 0.85; }
    50%      { transform: scale(1.07); opacity: 1;    }
  }
  .preloader__ring { stroke-dasharray: 220; stroke-dashoffset: 220; animation: plDraw 1.4s var(--ease) 0.2s forwards; }
  @keyframes plDraw { to { stroke-dashoffset: 0; } }

  .preloader__word {
    font-family: var(--font); font-weight: 700; letter-spacing: 0.38em; font-size: 16px;
    color: var(--alba); padding-left: 0.38em; margin-bottom: 26px;
    opacity: 0; animation: plUp 0.7s var(--ease) 0.9s forwards;
  }
  @keyframes plUp { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }

  .preloader__track { width: min(240px, 60vw); height: 3px; border-radius: 3px; background: rgba(255,255,255,0.10); overflow: hidden; }
  .preloader__fillbar {
    width: 0%; height: 100%; border-radius: 3px;
    background: linear-gradient(90deg, var(--verde), var(--acento));
    transition: width 0.3s var(--ease);
    box-shadow: 0 0 12px rgba(56,189,248,0.45);
  }
  .preloader__pct { margin-top: 12px; font-size: 12px; font-weight: 700; letter-spacing: 0.1em; color: var(--niebla); font-variant-numeric: tabular-nums; }

  @media (prefers-reduced-motion: reduce) {
    .preloader::before, .preloader__logo, .preloader__word { animation: none; }
    .preloader__logo { opacity: 1; transform: none; }
    .preloader__ring { stroke-dashoffset: 0; animation: none; }
    .preloader__word { opacity: 1; }
  }
</style>

<script>
  (() => {
    const pre = document.getElementById('preloader');
    if (!pre) return;
    const bar = pre.querySelector('[data-pl-bar]');
    const pct = pre.querySelector('[data-pl-pct]');

    document.documentElement.classList.add('is-loading');

    let shown = 0;
    let done = false;

    const calcReal = () => {
      const imgs = Array.from(document.images);
      if (!imgs.length) return 0.85;
      const ok = imgs.filter((im) => im.complete && im.naturalWidth > 0).length;
      return ok / imgs.length;
    };

    let pageLoaded = false;
    window.addEventListener('load', () => { pageLoaded = true; });

    const tick = () => {
      const real = pageLoaded ? 1 : Math.min(calcReal(), 0.92);
      const objetivo = real * 100;
      shown += Math.max(0.5, (objetivo - shown) * 0.12);
      if (shown > objetivo) shown = objetivo;
      if (shown > 100) shown = 100;

      if (bar) (bar as HTMLElement).style.width = shown.toFixed(1) + '%';
      if (pct) pct.textContent = Math.round(shown) + '%';

      if (pageLoaded && shown >= 99.5 && !done) {
        done = true;
        if (bar) (bar as HTMLElement).style.width = '100%';
        if (pct) pct.textContent = '100%';
        setTimeout(cerrar, 350);
        return;
      }
      requestAnimationFrame(tick);
    };

    const cerrar = () => {
      pre.classList.add('is-done');
      document.documentElement.classList.remove('is-loading');
      document.documentElement.classList.add('preloader-done');
      setTimeout(() => pre.remove(), 700);
    };

    setTimeout(() => { pageLoaded = true; }, 5000);
    requestAnimationFrame(tick);
  })();
</script>
