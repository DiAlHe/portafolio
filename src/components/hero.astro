<section id="hero">
  <div class="hero-bg"></div>
  <div class="hero-overlay"></div>

  <div class="hero-content">
    <p class="hero-tag" id="hero-tag">Full-Stack Developer</p>
    <h1 class="hero-title" id="hero-title">
      <span class="line">DIEGO</span>
      <span class="line accent">HERNANDEZ</span>
    </h1>
    <p class="hero-sub" id="hero-sub">
      Especializado en garantizar altos estándares de calidad, seguridad, rendimiento y automatización de procesos para mejorar la eficiencia operativa.<br/>
      Web · Mobile · APIs · Automatización · Base de datos
    </p>
    <div class="hero-cta" id="hero-cta">
      <a href="#proyectos" class="btn-primary">Ver proyectos</a>
      <a href="#contacto" class="btn-secondary">Hablemos</a>
    </div>
    <div class="hero-scroll" id="hero-scroll">
      <span>scroll</span>
      <div class="scroll-line"></div>
    </div>
  </div>
</section>

<style>
  #hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(230, 57, 70, 0.15) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 20%, rgba(244, 162, 97, 0.08) 0%, transparent 50%),
      #0a0a0a;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 60%, #0a0a0a 100%);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 120px 2rem 4rem;
    width: 100%;
    max-width: 1200px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-tag {
    font-size: 0.8rem;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
    opacity: 0;
  }

  .hero-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3.5rem, 10vw, 12rem);
    line-height: 0.9;
    letter-spacing: 4px;
    margin-bottom: 2rem;
    width: 100%;
  }

  .hero-title .line {
    display: block;
    opacity: 0;
    transform: translateY(80px);
  }

  .hero-title .accent {
    color: transparent;
    -webkit-text-stroke: 2px var(--color-accent);
  }

  .hero-sub {
    font-size: clamp(0.82rem, 1.5vw, 1rem);
    color: var(--color-muted);
    line-height: 1.8;
    margin-bottom: 2.5rem;
    opacity: 0;
    max-width: 700px;
  }

  .hero-cta {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    opacity: 0;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .btn-primary {
    padding: 1rem 2.5rem;
    background: var(--color-accent);
    color: white;
    text-decoration: none;
    font-size: 0.85rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-weight: 600;
    transition: all 0.3s ease;
    clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
  }

  .btn-primary:hover {
    background: var(--color-accent-2);
    transform: translateY(-2px);
  }

  .btn-secondary {
    padding: 1rem 2.5rem;
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    text-decoration: none;
    font-size: 0.85rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-weight: 600;
    transition: all 0.3s ease;
    clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
  }

  .btn-secondary:hover {
    background: rgba(230, 57, 70, 0.1);
    transform: translateY(-2px);
  }

  /* SCROLL — ahora dentro del flujo, no absoluto */
  .hero-scroll {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
  }

  .hero-scroll span {
    font-size: 0.65rem;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .scroll-line {
    width: 1px;
    height: 50px;
    background: linear-gradient(to bottom, var(--color-accent), transparent);
    animation: scrollPulse 2s ease infinite;
  }

  @keyframes scrollPulse {
    0% { transform: scaleY(0); transform-origin: top; }
    50% { transform: scaleY(1); transform-origin: top; }
    51% { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  @media (max-width: 1024px) {
    .hero-title {
      font-size: clamp(3rem, 9vw, 9rem);
    }

    .hero-content {
      padding: 110px 2rem 3rem;
    }
  }

  @media (max-width: 768px) {
    .hero-content {
      padding: 100px 1.5rem 3rem;
    }

    .hero-title {
      font-size: clamp(3rem, 14vw, 6rem);
      letter-spacing: 2px;
    }

    .hero-title .accent {
      -webkit-text-stroke: 1px var(--color-accent);
    }

    .hero-tag {
      font-size: 0.7rem;
      letter-spacing: 3px;
      margin-bottom: 1rem;
    }

    .hero-sub {
      font-size: 0.85rem;
      margin-bottom: 2rem;
    }

    .hero-cta {
      flex-direction: column;
      align-items: stretch;
      gap: 1rem;
      width: 100%;
      max-width: 320px;
      margin-bottom: 2rem;
    }

    .btn-primary,
    .btn-secondary {
      padding: 0.9rem 1.5rem;
      font-size: 0.78rem;
      text-align: center;
    }

    .hero-scroll {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .hero-content {
      padding: 90px 1.25rem 2.5rem;
    }

    .hero-title {
      font-size: clamp(2.8rem, 16vw, 5rem);
    }

    .hero-sub {
      font-size: 0.8rem;
    }

    .hero-tag {
      font-size: 0.65rem;
      letter-spacing: 2px;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';

  const tl = gsap.timeline({ delay: 0.3 });

  tl.to('#hero-tag', {
    opacity: 1,
    y: 0,
    duration: 0.8,
    ease: 'power3.out'
  })
  .to('.hero-title .line', {
    opacity: 1,
    y: 0,
    duration: 1,
    stagger: 0.15,
    ease: 'power4.out'
  }, '-=0.4')
  .to('#hero-sub', {
    opacity: 1,
    y: 0,
    duration: 0.8,
    ease: 'power3.out'
  }, '-=0.5')
  .to('#hero-cta', {
    opacity: 1,
    y: 0,
    duration: 0.8,
    ease: 'power3.out'
  }, '-=0.5')
  .to('#hero-scroll', {
    opacity: 1,
    duration: 0.8,
    ease: 'power3.out'
  }, '-=0.3');
</script>