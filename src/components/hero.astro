---
import { heroImagenes } from '../data/proyectos.ts';
import { useTranslations, type Lang } from '../i18n/index.ts';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const COLS = 5;
const ROWS = 4;
const columnas = Array.from({ length: COLS }, (_, c) =>
  Array.from({ length: ROWS }, (_, r) => heroImagenes[(c * ROWS + r) % heroImagenes.length])
);
---

<section class="hero" id="inicio">
  <div class="hero__bg" data-herobg aria-hidden="true">
    {columnas.map((col, c) => (
      <div class={`hero__col${c % 2 ? ' hero__col--reverse' : ''}`} data-col={c % 2}>
        {[...col, ...col].map((src, i) => (
          <div class="hero__tile">
            <img src={src} alt="" width="600" height="800"
              loading={c < 2 ? 'eager' : 'lazy'}
              fetchpriority={c < 2 && i < 2 ? 'high' : 'auto'}
              decoding="async" />
          </div>
        ))}
      </div>
    ))}
  </div>

  <div class="hero__veil" aria-hidden="true"></div>

  <div class="hero__inner" data-hero>
    <span class="eyebrow hero__eyebrow">{t.hero.eyebrow}</span>
    <h1 class="hero__title display">
      {t.hero.titleBefore} <span class="grad-text">{t.hero.titleHighlight}</span>
    </h1>
    <p class="hero__lede" set:html={t.hero.lede} />
    <div class="hero__cta">
      <a href="#experiencia" class="btn btn-primary">{t.hero.ctaExp}</a>
      <a href="#contacto" class="btn btn-ghost">{t.hero.ctaContact}</a>
    </div>
    <div class="hero__mark">
      <svg width="18" height="18" viewBox="0 0 60 60" fill="none" aria-hidden="true">
        <path d="M30 4 L52 17 L52 43 L30 56 L8 43 L8 17 Z" stroke="#38BDF8" stroke-width="2" fill="rgba(56,189,248,0.08)"/>
        <text x="30" y="32" text-anchor="middle" dominant-baseline="middle" font-family="Arial" font-weight="800" font-size="18" fill="#38BDF8">DH</text>
      </svg>
      <span>{t.hero.mark}</span>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative; min-height: 100svh;
    display: grid; align-items: center;
    padding-top: var(--nav-h);
    overflow: hidden; isolation: isolate;
  }

  .hero__bg {
    position: absolute; inset: 0; z-index: 0;
    display: flex; gap: clamp(10px, 1.4vw, 18px); justify-content: center; padding: 0 8px;
    opacity: 0;
    animation: bgReveal 1.1s var(--ease) forwards;
    animation-play-state: paused;
  }
  html.preloader-done .hero__bg { animation-play-state: running; }
  @keyframes bgReveal { to { opacity: 1; } }
  @media (prefers-reduced-motion: reduce) { .hero__bg { opacity: 1; animation: none; } }
  .hero__col { flex: 1 1 0; display: flex; flex-direction: column; gap: clamp(10px, 1.4vw, 18px); will-change: transform; }
  .hero__col--reverse { margin-top: -18%; }
  .hero__tile { position: relative; width: 100%; aspect-ratio: 3 / 4; border-radius: 14px; overflow: hidden; background: var(--nebula); border: 1px solid rgba(255,255,255,0.04); flex: 0 0 auto; }
  .hero__tile img { width: 100%; height: 100%; object-fit: cover; opacity: 0.85; }

  .hero__veil {
    position: absolute; inset: 0; z-index: 1; pointer-events: none;
    background:
      linear-gradient(180deg, rgba(6,11,20,0.65), transparent 16%, transparent 84%, var(--cosmos)),
      radial-gradient(60% 70% at 80% 18%, rgba(56,189,248,0.09), transparent 60%),
      radial-gradient(50% 60% at 12% 86%, rgba(52,211,153,0.07), transparent 60%);
  }

  .hero__inner { position: relative; z-index: 2; text-align: center; max-width: 900px; margin: 0 auto; padding: 40px var(--gutter); }

  .hero__inner::before {
    content: ""; position: absolute; z-index: -1;
    left: 50%; top: 46%; transform: translate(-50%, -50%);
    width: min(960px, 98vw); height: min(800px, 100svh);
    background: radial-gradient(ellipse 50% 50% at 50% 50%, rgba(4,8,18,0.98) 0%, rgba(4,8,18,0.95) 42%, rgba(4,8,18,0.78) 62%, rgba(4,8,18,0.40) 82%, transparent 100%);
    filter: blur(18px); border-radius: 50%;
    will-change: transform;
  }
  .hero__inner::after {
    content: ""; position: absolute; z-index: -1;
    left: 50%; top: 46%; transform: translate(-50%, -50%);
    width: min(680px, 86vw); height: min(560px, 84svh);
    background: radial-gradient(ellipse 50% 50% at 50% 50%, rgba(4,8,18,0.92) 0%, rgba(4,8,18,0.58) 55%, transparent 100%);
    filter: blur(10px); border-radius: 50%;
    will-change: transform;
  }

  .hero__eyebrow { margin-bottom: 22px; justify-content: center; font-size: larger; font-weight: bolder; }
  .hero__title { font-size: clamp(2.6rem, 6.6vw, 5.2rem); line-height: 0.98; margin-bottom: 26px; color: var(--alba); }
  .hero__lede { font-size: clamp(1rem, 2.2vw, 1.22rem); color: var(--niebla); max-width: 600px; margin: 0 auto 34px; line-height: 1.6; }
  .hero__lede :global(strong) { color: var(--alba); font-weight: 700; }
  .hero__cta { display: flex; flex-wrap: wrap; gap: 14px; align-items: center; justify-content: center; }
  .hero__mark { margin-top: 40px; display: inline-flex; align-items: center; gap: 10px; font-size: 13px; color: var(--niebla); flex-wrap: wrap; justify-content: center; }

  [data-hero] > * { opacity: 0; transform: translateY(26px); animation: heroIn 0.9s var(--ease) forwards; }
  [data-hero] > *:nth-child(1) { animation-delay: 0.15s; }
  [data-hero] > *:nth-child(2) { animation-delay: 0.28s; }
  [data-hero] > *:nth-child(3) { animation-delay: 0.41s; }
  [data-hero] > *:nth-child(4) { animation-delay: 0.54s; }
  [data-hero] > *:nth-child(5) { animation-delay: 0.67s; }
  @keyframes heroIn { to { opacity: 1; transform: none; } }

  @media (max-width: 860px) { .hero__col:nth-child(n+4) { display: none; } }
  @media (max-width: 560px) { .hero__col:nth-child(n+3) { display: none; } }
  @media (prefers-reduced-motion: reduce) {
    [data-hero] > * { opacity: 1; transform: none; animation: none; }
  }
</style>

<script>
  function initHero(): void {
    const hero = document.getElementById('inicio');
    if (!hero) return;
    const cols = Array.from(hero.querySelectorAll('[data-col]'));
    if (!cols.length) return;

    const clamp = (v: number, a: number, b: number): number => Math.max(a, Math.min(b, v));
    const SPEED = 0.012;
    let raf: number | null = null, last = performance.now();

    // Cache dimensions — only recalculate on resize, never inside the animation loop
    let heroDocTop = hero.offsetTop;
    let heroH      = hero.offsetHeight;
    let halfHeights = cols.map(col => (col as HTMLElement).scrollHeight / 2);
    let cachedScrollY = window.scrollY;
    window.addEventListener('scroll', () => { cachedScrollY = window.scrollY; }, { passive: true });
    window.addEventListener('resize', () => {
      heroDocTop = hero.offsetTop;
      heroH = hero.offsetHeight;
      halfHeights = cols.map(col => (col as HTMLElement).scrollHeight / 2);
    }, { passive: true });

    const tick = (now: number): void => {
      const dt = now - last; last = now;
      const vh = window.innerHeight;
      const relTop = heroDocTop - cachedScrollY;
      const scrollFactor = clamp((vh - relTop) / (vh + heroH), 0, 1);
      cols.forEach((col, i) => {
        const dir = i % 2 ? 1 : -1;
        let y = parseFloat((col as HTMLElement).dataset.y ?? '0');
        y += dir * SPEED * dt;
        const half = halfHeights[i] ?? 0;
        if (half > 0) { if (y <= -half) y += half; if (y >= 0) y -= half; }
        (col as HTMLElement).dataset.y = String(y);
        const shift = dir * scrollFactor * 80;
        (col as HTMLElement).style.transform = `translateY(${(y + shift).toFixed(2)}px)`;
      });
      raf = requestAnimationFrame(tick);
    };
    const start = (): void => { if (raf === null) { last = performance.now(); raf = requestAnimationFrame(tick); } };
    const stop  = (): void => { if (raf !== null) { cancelAnimationFrame(raf); raf = null; } };

    if ('IntersectionObserver' in window) {
      new IntersectionObserver(
        (es) => es.forEach((e) => (e.isIntersecting ? start() : stop())),
        { threshold: 0 }
      ).observe(hero);
    } else { start(); }
  }

  if (document.readyState !== 'loading') initHero();
  else document.addEventListener('DOMContentLoaded', initHero);
  document.addEventListener('astro:page-load', initHero);
</script>
