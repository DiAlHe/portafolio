---
import { useTranslations, type Lang } from '../i18n/index.ts';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const DI = 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons';
const SI = 'https://cdn.simpleicons.org';

const categorias = [
  {
    label: t.hab.cats[0],
    techs: [
      { name: 'Angular',    icon: `${DI}/angular/angular-original.svg` },
      { name: 'TypeScript', icon: `${DI}/typescript/typescript-original.svg` },
      { name: 'React',      icon: `${DI}/react/react-original.svg` },
      { name: 'JavaScript', icon: `${DI}/javascript/javascript-original.svg` },
      { name: 'Flutter',    icon: `${DI}/flutter/flutter-original.svg` },
      { name: 'Astro',      icon: `${SI}/astro/FF5D01` },
      { name: 'HTML5',      icon: `${DI}/html5/html5-original.svg` },
      { name: 'SCSS',       icon: `${DI}/sass/sass-original.svg` },
      { name: 'Tailwind',   icon: `${DI}/tailwindcss/tailwindcss-original.svg` },
    ],
  },
  {
    label: t.hab.cats[1],
    techs: [
      { name: 'Node.js',   icon: `${DI}/nodejs/nodejs-original.svg` },
      { name: 'Python',    icon: `${DI}/python/python-original.svg` },
      { name: 'FastAPI',   icon: `${DI}/fastapi/fastapi-original.svg` },
      { name: 'Django',    icon: `${DI}/django/django-plain.svg` },
      { name: 'Socket.io', icon: `${SI}/socketdotio/FFFFFF` },
      { name: 'C++',       icon: `${DI}/cplusplus/cplusplus-original.svg` },
      { name: 'Java',      icon: `${DI}/java/java-original.svg` },
    ],
  },
  {
    label: t.hab.cats[2],
    techs: [
      { name: 'MySQL',      icon: `${DI}/mysql/mysql-original.svg` },
      { name: 'MariaDB',    icon: `${DI}/mariadb/mariadb-original.svg` },
      { name: 'SQL Server', icon: `${DI}/microsoftsqlserver/microsoftsqlserver-original.svg` },
      { name: 'Oracle',     icon: `${DI}/oracle/oracle-original.svg` },
      { name: 'PostgreSQL', icon: `${DI}/postgresql/postgresql-original.svg` },
    ],
  },
  {
    label: t.hab.cats[3],
    techs: [
      { name: 'Docker', icon: `${DI}/docker/docker-original.svg` },
      { name: 'Git',    icon: `${DI}/git/git-original.svg` },
      { name: 'GitHub', icon: `${SI}/github/FFFFFF` },
      { name: 'Figma',  icon: `${DI}/figma/figma-original.svg` },
      { name: 'Leaflet',icon: `${SI}/leaflet/199900` },
      { name: 'GSAP',   icon: `${SI}/greensock/88CE02` },
      { name: 'n8n',    icon: `${SI}/n8n/EA4B71` },
    ],
  },
];
---

<section id="habilidades" class="hab section">
  <div class="container">

    <div class="hab__head" data-reveal>
      <span class="eyebrow">{t.hab.eyebrow}</span>
      <h2 class="hab__title">
        {t.hab.titleBefore} <span class="grad-text">{t.hab.titleHighlight}</span>
      </h2>
    </div>

    <div class="hab__cats">
      {categorias.map((cat, ci) => (
        <div class="hab__cat" data-cat data-delay={ci * 0.08}>
          <div class="hab__cat-label">
            <span>{cat.label}</span>
          </div>
          <div class="hab__icons">
            {cat.techs.map(tech => (
              <div class="hab__icon">
                <div class="hab__icon-wrap">
                  <img
                    src={tech.icon}
                    alt={tech.name}
                    width="36"
                    height="36"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <span class="hab__icon-name">{tech.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .hab {
    background: rgba(255,255,255,0.008);
    border-top: 1px solid rgba(255,255,255,0.04);
  }

  .hab__head { margin-bottom: clamp(40px, 6vw, 64px); }
  .hab__title {
    font-size: clamp(2.6rem, 6vw, 5rem);
    font-weight: 700; letter-spacing: -0.03em; line-height: 0.95; margin-top: 16px;
    opacity: 0; transform: translateY(48px);
  }
  @media (prefers-reduced-motion: reduce) { .hab__title { opacity: 1; transform: none; } }

  /* ── Categorías ── */
  .hab__cats { display: flex; flex-direction: column; gap: clamp(36px, 5vw, 52px); }
  .hab__cat  { opacity: 0; transform: translateY(24px); }

  .hab__cat-label {
    display: flex; align-items: center; gap: 14px;
    margin-bottom: 18px;
  }
  .hab__cat-label span {
    font-size: 10px; letter-spacing: 0.26em; text-transform: uppercase;
    color: var(--niebla); font-weight: 600; white-space: nowrap;
  }
  .hab__cat-label::after {
    content: ''; flex: 1; height: 1px;
    background: linear-gradient(to right, rgba(255,255,255,0.1), transparent);
  }

  /* ── Grid de iconos ── */
  .hab__icons {
    display: flex; flex-wrap: wrap; gap: 10px;
  }

  .hab__icon {
    display: flex; flex-direction: column; align-items: center; gap: 9px;
    width: 82px; padding: 18px 8px 14px;
    border-radius: 16px;
    border: 1px solid rgba(255,255,255,0.07);
    background: rgba(255,255,255,0.025);
    transition: transform 0.28s var(--ease), border-color 0.28s, background 0.28s, box-shadow 0.28s;
    cursor: default;
  }
  .hab__icon:hover {
    transform: translateY(-5px);
    border-color: rgba(56,189,248,0.35);
    background: rgba(56,189,248,0.06);
    box-shadow: 0 10px 28px -10px rgba(56,189,248,0.22);
  }

  .hab__icon-wrap {
    width: 36px; height: 36px;
    display: grid; place-items: center;
  }
  .hab__icon-wrap img {
    width: 36px; height: 36px;
    object-fit: contain;
  }

  .hab__icon-name {
    font-size: 9.5px; color: var(--niebla);
    letter-spacing: 0.03em; text-align: center; line-height: 1.3;
  }

  @media (max-width: 480px) {
    .hab__icon { width: 72px; padding: 14px 6px 12px; }
    .hab__title { font-size: clamp(2.4rem, 10vw, 4rem); }
  }
</style>

<script>
  async function initHabilidades(): Promise<void> {
    const section = document.getElementById('habilidades');
    if (!section) return;

    const run = async (): Promise<void> => {
      const [{ gsap }, { ScrollTrigger }] = await Promise.all([
        import('gsap'),
        import('gsap/ScrollTrigger'),
      ]);
      gsap.registerPlugin(ScrollTrigger);

      const titulo = section.querySelector('.hab__title');
      if (titulo) {
        gsap.to(titulo, {
          opacity: 1, y: 0, duration: 1, ease: 'power4.out',
          scrollTrigger: { trigger: section, start: 'top 78%' },
        });
      }

      section.querySelectorAll('[data-cat]').forEach((cat: any) => {
        const delay = parseFloat(cat.getAttribute('data-delay') || '0');
        gsap.to(cat, {
          opacity: 1, y: 0, duration: 0.7, delay, ease: 'power3.out',
          scrollTrigger: { trigger: section, start: 'top 72%' },
        });
      });
    };

    const io = new IntersectionObserver(
      ([entry]) => {
        if (!entry?.isIntersecting) return;
        io.disconnect();
        run();
      },
      { rootMargin: '300px 0px' }
    );
    io.observe(section);
  }

  if (document.readyState !== 'loading') initHabilidades();
  else document.addEventListener('DOMContentLoaded', initHabilidades);
  document.addEventListener('astro:page-load', initHabilidades);
</script>
