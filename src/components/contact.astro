<section id="contacto">
  <div class="contact-inner">

    <div class="contact-top">
      <div class="section-label">
        <span class="label-line"></span>
        <span class="label-text">Contacto</span>
      </div>
      <h2 class="contact-title">
        <span class="reveal-text">¿Tienes un</span>
        <span class="reveal-text accent-stroke">proyecto?</span>
        <span class="reveal-text">Hablemos.</span>
      </h2>
    </div>

    <div class="contact-grid">
      <div class="contact-info reveal-left">
        <p class="contact-desc">
          Estoy disponible para proyectos freelance, trabajo remoto y
          oportunidades full-time. Apasionado por dar soluciones tecnologicas
          modernas y a aprender nuevas tecnologias.
        </p>
        <div class="contact-links">
          <a href="mailto:diegozx000@gmail.com" class="contact-link">
            <span class="link-icon">✉</span>
            <div>
              <span class="link-label">Email</span>
              <span class="link-value">diegozx000@gmail.com</span>
            </div>
          </a>
          <a href="https://linkedin.com/in/diegoalejandrohernandez-fullstackprogrammer" target="_blank" class="contact-link">
            <span class="link-icon">in</span>
            <div>
              <span class="link-label">LinkedIn</span>
              <span class="link-value">Diego Alejandro Hernandez</span>
            </div>
          </a>
        </div>
      </div>

      <div class="contact-cta reveal-right">
        <div class="cta-box">
          <p class="cta-text">¿Listo para empezar?</p>
          <a href="mailto:diegozx000@gmail.com" class="btn-cta">
            Enviar mensaje
          </a>
          <div class="availability">
            <span class="dot-green"></span>
            <span>Disponible para proyectos remotos</span>
          </div>
        </div>
      </div>
    </div>

    <div class="contact-footer">
      <p class="footer-copy">
        © {new Date().getFullYear()} Diego Alejandro Hernandez — Construido con Astro & GSAP
      </p>
      <div class="footer-links">
        <a href="#hero">Inicio</a>
        <a href="#sobre-mi">Sobre mí</a>
        <a href="#proyectos">Proyectos</a>
        <a href="#habilidades">Habilidades</a>
      </div>
    </div>

  </div>
</section>

<style>
  #contacto {
    padding: 8rem 6rem 4rem;
    border-top: 1px solid rgba(255,255,255,0.04);
    position: relative;
    overflow: hidden;
  }

  #contacto::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(230,57,70,0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .contact-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .label-line {
    width: 40px;
    height: 1px;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  .label-text {
    font-size: 0.75rem;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .contact-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 8vw, 8rem);
    line-height: 0.9;
    letter-spacing: 2px;
    margin-bottom: 5rem;
  }

  .reveal-text {
    display: block;
    opacity: 0;
    transform: translateY(60px);
  }

  .accent-stroke {
    color: transparent;
    -webkit-text-stroke: 2px var(--color-accent);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
    margin-bottom: 6rem;
  }

  .reveal-left {
    opacity: 0;
    transform: translateX(-50px);
  }

  .reveal-right {
    opacity: 0;
    transform: translateX(50px);
  }

  .contact-desc {
    font-size: 1rem;
    line-height: 1.9;
    color: var(--color-muted);
    margin-bottom: 3rem;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    text-decoration: none;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    transition: all 0.3s ease;
  }

  .contact-link:hover {
    padding-left: 0.5rem;
  }

  .contact-link:hover .link-value {
    color: var(--color-accent);
  }

  .link-icon {
    width: 42px;
    height: 42px;
    border: 1px solid rgba(230,57,70,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    color: var(--color-accent);
    flex-shrink: 0;
    font-weight: 700;
    border-radius: 2px;
  }

  .link-label {
    display: block;
    font-size: 0.65rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 0.2rem;
  }

  .link-value {
    font-size: 0.9rem;
    color: var(--color-text);
    transition: color 0.3s ease;
  }

  .cta-box {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.07);
    border-top: 2px solid var(--color-accent);
    padding: 3.5rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: flex-start;
    border-radius: 2px;
  }

  .cta-text {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    letter-spacing: 2px;
    color: var(--color-text);
  }

  .btn-cta {
    display: inline-block;
    padding: 1.1rem 3rem;
    background: var(--color-accent);
    color: white;
    text-decoration: none;
    font-size: 0.85rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-weight: 600;
    transition: all 0.3s ease;
    clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
    width: 100%;
    text-align: center;
  }

  .btn-cta:hover {
    background: var(--color-accent-2);
    transform: translateY(-2px);
  }

  .availability {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: var(--color-muted);
    letter-spacing: 1px;
  }

  .dot-green {
    width: 8px;
    height: 8px;
    background: #4ade80;
    border-radius: 50%;
    animation: pulse-green 2s ease infinite;
    flex-shrink: 0;
  }

  @keyframes pulse-green {
    0%, 100% { box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.4); }
    50% { box-shadow: 0 0 0 6px rgba(74, 222, 128, 0); }
  }

  .contact-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.05);
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-copy {
    font-size: 0.75rem;
    color: rgba(136,136,136,0.5);
    letter-spacing: 1px;
  }

  .footer-links {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .footer-links a {
    font-size: 0.72rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(136,136,136,0.5);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .footer-links a:hover {
    color: var(--color-accent);
  }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    #contacto {
      padding: 6rem 3rem 3rem;
    }

    .contact-grid {
      gap: 4rem;
    }
  }

  @media (max-width: 768px) {
    #contacto {
      padding: 5rem 1.5rem 3rem;
    }

    .contact-title {
      font-size: clamp(2.5rem, 10vw, 4rem);
      margin-bottom: 3rem;
    }

    .accent-stroke {
      -webkit-text-stroke: 1px var(--color-accent);
    }

    .contact-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
      margin-bottom: 3rem;
    }

    .reveal-left {
      transform: translateX(0);
    }

    .reveal-right {
      transform: translateX(0);
    }

    .cta-box {
      padding: 2rem 1.5rem;
    }

    .contact-desc {
      font-size: 0.92rem;
      margin-bottom: 2rem;
    }

    .link-value {
      font-size: 0.82rem;
    }

    .contact-footer {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .footer-links {
      gap: 1.25rem;
    }
  }

  @media (max-width: 480px) {
    #contacto {
      padding: 4rem 1.25rem 2.5rem;
    }

    .cta-box {
      padding: 1.5rem 1.25rem;
    }

    .btn-cta {
      padding: 1rem 1.5rem;
      font-size: 0.78rem;
    }

    .footer-links {
      gap: 1rem;
    }

    .footer-links a {
      font-size: 0.65rem;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.to('.contact-title .reveal-text', {
    opacity: 1,
    y: 0,
    duration: 1,
    stagger: 0.2,
    ease: 'power4.out',
    scrollTrigger: {
      trigger: '#contacto',
      start: 'top 75%',
    }
  });

  gsap.to('.reveal-left', {
    opacity: 1,
    x: 0,
    duration: 1,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '.contact-grid',
      start: 'top 80%',
    }
  });

  gsap.to('.reveal-right', {
    opacity: 1,
    x: 0,
    duration: 1,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '.contact-grid',
      start: 'top 80%',
    }
  });
</script>