<style>
  #sobre-mi {
    padding: 8rem 6rem;
    position: relative;
    overflow: hidden;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .label-line {
    width: 40px;
    height: 1px;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  .label-text {
    font-size: 0.75rem;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .about-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 5vw, 5.5rem);
    line-height: 1;
    letter-spacing: 2px;
    margin-bottom: 3rem;
  }

  .reveal-text {
    display: block;
    opacity: 0;
    transform: translateY(60px);
  }

  .accent-stroke {
    color: transparent;
    -webkit-text-stroke: 1.5px var(--color-accent);
  }

  .about-stats {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .stat {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
  }

  .stat-number {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    color: var(--color-accent);
    line-height: 1;
  }

  .stat-unit {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--color-accent);
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--color-muted);
    letter-spacing: 1px;
    margin-left: 0.75rem;
    text-transform: uppercase;
  }

  .reveal-card {
    opacity: 0;
    transform: translateX(60px);
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-left: 2px solid var(--color-accent);
    padding: 3rem;
    border-radius: 2px;
  }

  .about-description {
    font-size: 1rem;
    line-height: 1.9;
    color: rgba(241,241,241,0.75);
    margin-bottom: 1.25rem;
  }

  .about-description strong {
    color: var(--color-text);
    font-weight: 600;
  }

  .about-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 2rem;
  }

  .tag {
    padding: 0.4rem 1rem;
    border: 1px solid rgba(230, 57, 70, 0.4);
    color: var(--color-accent);
    font-size: 0.75rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    border-radius: 1px;
    background: rgba(230, 57, 70, 0.05);
  }

  .marquee-wrapper {
    margin-top: 6rem;
    overflow: hidden;
    border-top: 1px solid rgba(255,255,255,0.05);
    border-bottom: 1px solid rgba(255,255,255,0.05);
    padding: 1.5rem 0;
  }

  .marquee-track {
    display: flex;
    gap: 3rem;
    white-space: nowrap;
    animation: marquee 20s linear infinite;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.2rem;
    letter-spacing: 3px;
    color: var(--color-muted);
  }

  .marquee-track .dot {
    color: var(--color-accent);
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    #sobre-mi {
      padding: 6rem 3rem;
    }

    .about-grid {
      gap: 4rem;
    }
  }

  @media (max-width: 768px) {
    #sobre-mi {
      padding: 5rem 1.5rem;
    }

    .about-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .about-title {
      font-size: clamp(2.5rem, 10vw, 4rem);
      margin-bottom: 2rem;
    }

    .accent-stroke {
      -webkit-text-stroke: 1px var(--color-accent);
    }

    .reveal-card {
      padding: 1.75rem;
      transform: translateX(0);
    }

    .about-description {
      font-size: 0.92rem;
    }

    .about-stats {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 1.5rem 2rem;
    }

    .stat-label {
      font-size: 0.72rem;
      margin-left: 0;
      display: block;
    }

    .marquee-wrapper {
      margin-top: 3rem;
    }

    .marquee-track {
      font-size: 1rem;
      gap: 2rem;
    }
  }

  @media (max-width: 480px) {
    #sobre-mi {
      padding: 4rem 1.25rem;
    }

    .reveal-card {
      padding: 1.25rem;
    }

    .about-stats {
      gap: 1rem;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.to('.reveal-text', {
    opacity: 1,
    y: 0,
    duration: 1,
    stagger: 0.2,
    ease: 'power4.out',
    scrollTrigger: {
      trigger: '#sobre-mi',
      start: 'top 75%',
    }
  });

  gsap.to('.reveal-card', {
    opacity: 1,
    x: 0,
    duration: 1,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '.reveal-card',
      start: 'top 80%',
    }
  });

  document.querySelectorAll('.stat-number').forEach((el) => {
    const target = parseInt(el.getAttribute('data-target') || '0');
    ScrollTrigger.create({
      trigger: el,
      start: 'top 85%',
      onEnter: () => {
        gsap.to({ val: 0 }, {
          val: target,
          duration: 2,
          ease: 'power2.out',
          onUpdate: function() {
            el.textContent = Math.round(this.targets()[0].val).toString();
          }
        });
      },
      once: true
    });
  });
</script>