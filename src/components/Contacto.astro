---
import { iconos } from '../data/iconos.ts';
import { useTranslations, type Lang } from '../i18n/index.ts';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="contacto section" id="contacto">
  <div class="container">

    <div class="contacto__head" data-reveal>
      <span class="eyebrow">{t.contacto.eyebrow}</span>
      <h2 class="contacto__title display">{t.contacto.title}</h2>
      <p class="contacto__lede">{t.contacto.lede}</p>
    </div>

    <div class="contacto__cards" data-reveal>
      <a class="contacto__card" href="mailto:diegozx000@gmail.com">
        <span class="contacto__card-ic"><Fragment set:html={iconos.mail()} /></span>
        <span class="contacto__card-info">
          <b>{t.contacto.cardEmail}</b>
          <span>diegozx000@gmail.com</span>
        </span>
      </a>

      <a class="contacto__card" href="https://linkedin.com/in/diegoalejandrohernandez-fullstackprogrammer" target="_blank" rel="noopener noreferrer">
        <span class="contacto__card-ic">
          <svg viewBox="0 0 24 24" fill="none" stroke="var(--acento)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>
          </svg>
        </span>
        <span class="contacto__card-info">
          <b>{t.contacto.cardLinkedIn}</b>
          <span>diegoalejandrohernandez</span>
        </span>
      </a>

      <div class="contacto__card">
        <span class="contacto__card-ic"><Fragment set:html={iconos.pin()} /></span>
        <span class="contacto__card-info">
          <b>{t.contacto.cardLocation}</b>
          <span>{t.contacto.location}</span>
        </span>
      </div>
    </div>

    <div class="contacto__footer" data-reveal>
      <div class="contacto__disponible">
        <span class="contacto__dot"></span>
        <span>{t.contacto.disponible}</span>
      </div>
      <a href="mailto:diegozx000@gmail.com" class="btn btn-primary">{t.contacto.cta}</a>
    </div>

  </div>
</section>

<style>
  .contacto { position: relative; overflow: hidden; }
  .contacto::before {
    content: ""; position: absolute; inset: 0; pointer-events: none;
    background:
      radial-gradient(ellipse 50% 60% at 90% 10%, rgba(56,189,248,0.08), transparent 60%),
      radial-gradient(ellipse 44% 50% at 8% 92%, rgba(52,211,153,0.06), transparent 60%);
  }

  .contacto__head { text-align: center; max-width: 640px; margin: 0 auto clamp(40px, 6vw, 64px); }
  .contacto__title { font-size: clamp(2rem, 5vw, 3.4rem); color: var(--alba); margin: 16px 0 20px; }
  .contacto__lede { color: var(--niebla); line-height: 1.7; font-size: 1.05rem; }

  .contacto__cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: clamp(32px, 5vw, 48px); }
  .contacto__card {
    display: flex; align-items: center; gap: 16px; padding: 22px 24px;
    border-radius: 14px; border: 1px solid rgba(255,255,255,0.07);
    background: rgba(255,255,255,0.015);
    transition: transform 0.4s var(--ease), border-color 0.4s, box-shadow 0.4s;
  }
  .contacto__card:hover { transform: translateY(-4px); border-color: rgba(56,189,248,0.35); box-shadow: 0 16px 40px -16px rgba(56,189,248,0.12); }
  .contacto__card-ic {
    flex: 0 0 auto; width: 48px; height: 48px; border-radius: 13px; display: grid; place-items: center;
    background: rgba(52,211,153,0.08); border: 1px solid rgba(52,211,153,0.24);
  }
  .contacto__card-ic :global(svg) { width: 22px; height: 22px; }
  .contacto__card-info { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
  .contacto__card b { font-size: 11px; color: var(--niebla); letter-spacing: 0.14em; text-transform: uppercase; }
  .contacto__card span:last-child { font-size: 0.95rem; color: var(--alba); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .contacto__footer { display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
  .contacto__disponible { display: flex; align-items: center; gap: 10px; font-size: 13px; color: var(--niebla); }
  .contacto__dot {
    width: 8px; height: 8px; border-radius: 50%; background: var(--verde); flex: 0 0 auto;
    position: relative;
  }
  .contacto__dot::after {
    content: ''; position: absolute; inset: -3px; border-radius: 50%;
    background: rgba(52,211,153,0.25);
    animation: dotPulse 2s ease infinite;
    will-change: transform, opacity;
  }
  @keyframes dotPulse {
    0%,100% { transform: scale(1);   opacity: 1; }
    50%      { transform: scale(1.9); opacity: 0; }
  }

  @media (max-width: 860px)  { .contacto__cards { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 540px)  { .contacto__cards { grid-template-columns: 1fr; } }
  @media (max-width: 640px)  { .contacto__footer { flex-direction: column; align-items: flex-start; } }
</style>
