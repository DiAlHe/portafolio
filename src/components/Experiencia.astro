---
import { proyectos } from '../data/proyectos.ts';
import { useTranslations, type Lang } from '../i18n/index.ts';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const categorias = [
  { id: 'todos',       label: t.exp.filtros[0] },
  { id: 'SIT',        label: t.exp.filtros[1] },
  { id: 'FHIS',       label: t.exp.filtros[2] },
  { id: 'Consultoría', label: t.exp.filtros[3] },
];
---

<section class="exp section" id="experiencia">
  <div class="container">
    <div class="exp__head" data-reveal>
      <span class="eyebrow">{t.exp.eyebrow}</span>
      <h2 class="exp__title display">
        {t.exp.titleBefore} <span class="grad-text">{t.exp.titleHighlight}</span>
      </h2>
      <p class="exp__sub">{t.exp.sub}</p>
    </div>

    <div class="exp__filtros" data-filtros role="tablist"
         aria-label={lang === 'en' ? 'Filter projects' : 'Filtrar proyectos'}>
      {categorias.map((c, i) => (
        <button
          class={`exp__filtro${i === 0 ? ' active' : ''}`}
          data-filtro={c.id}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
        >
          {c.label}
        </button>
      ))}
    </div>

    <div class="exp__grid" data-grid>
      {proyectos.map((p, i) => {
        const nombre        = lang === 'en' ? (p.nombreEn        ?? p.nombre)        : p.nombre;
        const desc          = lang === 'en' ? (p.descEn          ?? p.desc)          : p.desc;
        const empresaNombre = lang === 'en' ? (p.empresaNombreEn ?? p.empresaNombre) : p.empresaNombre;
        const pillLabel     = p.empresa === 'Consultoría' ? t.exp.consultoria : p.empresa;
        return (
          <article class="exp__card" data-empresa={p.empresa} data-idx={i}>
            <div class="exp__card-grafico">
              <img src={p.imagen} alt={nombre} loading="lazy" decoding="async" />
            </div>
            <div class="exp__card-body">
              <div class="exp__card-meta">
                <span class={`pill ${p.empresa === 'Consultoría' ? 'pill-verde' : 'pill-acento'}`}>
                  {pillLabel}
                </span>
                <span class="exp__periodo">{p.periodo}</span>
              </div>
              <h3 class="exp__card-title">{nombre}</h3>
              <p class="exp__card-desc">{desc}</p>
              <div class="exp__card-tags">
                {p.tags.map((tag) => <span class="exp__tag">{tag}</span>)}
              </div>
            </div>
          </article>
        );
      })}
    </div>

    <div class="exp__paginacion" data-paginacion aria-live="polite"></div>
  </div>
</section>

<style>
  .exp { position: relative; overflow: hidden; }
  .exp::before {
    content: ""; position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(ellipse 46% 50% at 4% 10%, rgba(52,211,153,0.06), transparent 55%),
                radial-gradient(ellipse 40% 50% at 96% 90%, rgba(56,189,248,0.06), transparent 55%);
  }

  .exp__head { max-width: 680px; margin-bottom: clamp(40px, 6vw, 64px); }
  .exp__title { font-size: clamp(2rem, 5vw, 3.4rem); color: var(--alba); margin: 16px 0 18px; }
  .exp__sub { color: var(--niebla); font-size: 1.05rem; line-height: 1.6; }

  .exp__filtros { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: clamp(32px, 5vw, 48px); }
  .exp__filtro {
    padding: 9px 22px; border-radius: 100px; font-size: 13px; font-weight: 600;
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.10);
    color: var(--niebla); cursor: pointer; transition: 0.3s var(--ease);
  }
  .exp__filtro:hover { border-color: rgba(56,189,248,0.4); color: var(--acento); }
  .exp__filtro.active { background: rgba(56,189,248,0.12); border-color: rgba(56,189,248,0.4); color: var(--acento); }

  .exp__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; min-height: 200px; }

  .exp__card {
    border-radius: var(--radius); overflow: hidden;
    background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.01));
    border: 1px solid rgba(255,255,255,0.07);
    transition: transform 0.4s var(--ease), border-color 0.4s, box-shadow 0.4s;
    display: flex; flex-direction: column;
  }
  .exp__card:hover { transform: translateY(-6px); border-color: rgba(56,189,248,0.3); box-shadow: 0 20px 60px -20px rgba(56,189,248,0.15); }
  .exp__card.hidden { display: none; }

  .exp__card-grafico { width: 100%; aspect-ratio: 3/2; overflow: hidden; border-bottom: 1px solid rgba(255,255,255,0.05); }
  .exp__card-grafico img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s var(--ease); }
  .exp__card:hover .exp__card-grafico img { transform: scale(1.05); }

  .exp__card-body { padding: 20px 22px 24px; display: flex; flex-direction: column; flex: 1; }
  .exp__card-meta { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; flex-wrap: wrap; }
  .exp__periodo { font-size: 11px; color: var(--niebla); letter-spacing: 0.04em; }
  .exp__card-title { font-size: 1.05rem; font-weight: 700; color: var(--alba); margin-bottom: 10px; line-height: 1.3; }
  .exp__card-desc { font-size: 0.88rem; color: var(--niebla); line-height: 1.6; margin-bottom: 16px; flex: 1; }
  .exp__card-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .exp__tag {
    font-size: 10px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;
    padding: 4px 10px; border-radius: 6px;
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
    color: var(--niebla);
  }

  .exp__paginacion { display: flex; justify-content: center; align-items: center; gap: 8px; margin-top: clamp(32px, 5vw, 48px); flex-wrap: wrap; }
  .exp__paginacion :global(.pag-btn) {
    min-width: 40px; height: 40px; border-radius: 10px; padding: 0 14px;
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.10);
    color: var(--niebla); font-size: 13px; font-weight: 600; cursor: pointer;
    transition: 0.3s var(--ease); display: inline-flex; align-items: center; justify-content: center;
  }
  .exp__paginacion :global(.pag-btn:hover) { border-color: rgba(56,189,248,0.4); color: var(--acento); }
  .exp__paginacion :global(.pag-btn.active) { background: rgba(56,189,248,0.12); border-color: rgba(56,189,248,0.4); color: var(--acento); }
  .exp__paginacion :global(.pag-info) { font-size: 12px; color: var(--niebla); padding: 0 8px; }

  @media (max-width: 1024px) { .exp__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .exp__grid { grid-template-columns: 1fr; } }
  @media (max-width: 480px)  { .exp__filtro { padding: 8px 14px; font-size: 12px; } }
</style>

<script>
  function initExperiencia(): void {
    const grid = document.querySelector('[data-grid]');
    const filtros = document.querySelectorAll('[data-filtro]');
    const paginacion = document.querySelector('[data-paginacion]');
    if (!grid || !filtros.length) return;

    const POR_PAGINA = 6;
    let filtroActivo = 'todos';
    let paginaActual = 1;

    const todasLasCards = (): Element[] => Array.from(grid.querySelectorAll('.exp__card'));

    const cardsFiltradas = (): Element[] => {
      const cards = todasLasCards();
      if (filtroActivo === 'todos') return cards;
      return cards.filter((c) => (c as HTMLElement).dataset.empresa === filtroActivo);
    };

    const renderPaginacion = (total: number, pagina: number): void => {
      if (!paginacion) return;
      const totalPags = Math.ceil(total / POR_PAGINA);
      if (totalPags <= 1) { paginacion.innerHTML = ''; return; }

      let html = '';
      if (pagina > 1)
        html += `<button class="pag-btn" data-pag="${pagina - 1}">←</button>`;
      for (let i = 1; i <= totalPags; i++)
        html += `<button class="pag-btn${i === pagina ? ' active' : ''}" data-pag="${i}">${i}</button>`;
      if (pagina < totalPags)
        html += `<button class="pag-btn" data-pag="${pagina + 1}">→</button>`;
      html += `<span class="pag-info">${pagina} / ${totalPags}</span>`;
      paginacion.innerHTML = html;

      paginacion.querySelectorAll('[data-pag]').forEach((btn) => {
        btn.addEventListener('click', () => {
          paginaActual = parseInt((btn as HTMLElement).dataset.pag ?? '1');
          aplicar();
          grid.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });
    };

    const aplicar = (): void => {
      const visibles = cardsFiltradas();
      const inicio = (paginaActual - 1) * POR_PAGINA;
      const fin = inicio + POR_PAGINA;
      todasLasCards().forEach((c) => c.classList.add('hidden'));
      visibles.forEach((c, i) => { if (i >= inicio && i < fin) c.classList.remove('hidden'); });
      renderPaginacion(visibles.length, paginaActual);
    };

    filtros.forEach((btn) => {
      btn.addEventListener('click', () => {
        filtros.forEach((b) => { b.classList.remove('active'); b.setAttribute('aria-selected', 'false'); });
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');
        filtroActivo = (btn as HTMLElement).dataset.filtro ?? 'todos';
        paginaActual = 1;
        aplicar();
      });
    });

    aplicar();
  }

  if (document.readyState !== 'loading') initExperiencia();
  else document.addEventListener('DOMContentLoaded', initExperiencia);
  document.addEventListener('astro:page-load', initExperiencia);
</script>
