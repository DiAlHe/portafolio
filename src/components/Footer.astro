---
import { useTranslations, type Lang } from '../i18n/index.ts';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const year = new Date().getFullYear();

const links = [
  { href: '#inicio',       label: t.nav.home },
  { href: '#sobre-mi',    label: t.nav.about },
  { href: '#experiencia', label: t.nav.experience },
  { href: '#habilidades', label: t.nav.skills },
  { href: '#contacto',    label: t.nav.contact },
];
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <svg width="30" height="30" viewBox="0 0 60 60" fill="none" aria-hidden="true">
        <path d="M30 4 L52 17 L52 43 L30 56 L8 43 L8 17 Z" fill="rgba(56,189,248,0.08)" stroke="rgba(56,189,248,0.3)" stroke-width="1.2"/>
        <text x="30" y="32" text-anchor="middle" dominant-baseline="middle"
          font-family="Helvetica Neue, Arial, sans-serif" font-weight="800" font-size="16"
          fill="#38BDF8" letter-spacing="-0.5">DH</text>
      </svg>
      <div>
        <p class="footer__name">Diego Alejandro Hernandez</p>
        <p class="footer__tag">{t.footer.tag}</p>
      </div>
    </div>

    <nav class="footer__nav" aria-label={lang === 'en' ? 'Footer navigation' : 'Pie de página'}>
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
  </div>

  <hr class="hairline" />

  <div class="container footer__bottom">
    <span>© {year} Diego Alejandro Hernandez</span>
    <span>{t.footer.made}</span>
  </div>
</footer>

<style>
  .footer { background: var(--cosmos); padding-top: 64px; border-top: 1px solid rgba(255,255,255,0.05); }
  .footer__inner { display: flex; justify-content: space-between; align-items: flex-start; gap: 32px; flex-wrap: wrap; padding-bottom: 40px; }
  .footer__brand { display: flex; align-items: center; gap: 14px; }
  .footer__name { font-size: 15px; font-weight: 700; color: var(--alba); }
  .footer__tag { font-size: 12px; font-style: italic; color: var(--niebla); margin-top: 3px; }
  .footer__nav { display: flex; flex-wrap: wrap; gap: 24px; }
  .footer__nav a { font-size: 14px; color: var(--niebla); transition: color 0.3s; }
  .footer__nav a:hover { color: var(--acento); }
  .footer__bottom { display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap; padding: 24px 0 40px; font-size: 12px; color: var(--niebla); letter-spacing: 0.04em; }

  @media (max-width: 600px) {
    .footer__inner { flex-direction: column; gap: 28px; }
    .footer__nav { gap: 16px; }
    .footer__bottom { flex-direction: column; gap: 6px; }
  }
</style>
